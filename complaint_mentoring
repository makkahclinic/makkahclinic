        const c = normalizeComplaint(x);
        return {
          'رقم الشكوى': c.id,
          'التاريخ': c.date,
          'الوقت': c.time,
          'النوع': c.complaintType,
          'مقدم الشكوى': c.complainantName,
          'الجوال': c.complainantPhone,
          'البريد': c.complainantEmail,
          'الموقع': c.locations,
          'الشكوى ضد': c.complaintAgainst,
          'الوصف': c.complaintDescription,
          'الحالة': STATUS_NAME[c.status] || c.status,
          'الأولوية': c.priority,
          'المسؤول': c.assignedTo,
          'الحل': c.resolution
