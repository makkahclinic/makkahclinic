              <th>التاريخ</th>
              <th>النوع</th>
              <th>مقدم الشكوى</th>
              <th>الموقع</th>
              ${showAssigned ? `<th>المسؤول</th>` : ``}
              <th>الحالة</th>
              <th>أولوية</th>
