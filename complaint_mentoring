    async function loadAll() {
      const cont = document.getElementById('tblAll');
      cont.innerHTML = `<div class="loading"><i class="fa-solid fa-spinner fa-spin"></i></div>`;

      const status = document.getElementById('fStatus').value;
      const complaintType = document.getElementById('fType').value;
      const q = (document.getElementById('fSearch').value || '').trim().toLowerCase();

      const r = await api('getComplaints', { status, complaintType });
      if (!r.ok || !Array.isArray(r.complaints)) {
        cont.innerHTML = `<div class="empty"><i class="fa-solid fa-triangle-exclamation"></i> فشل تحميل البيانات</div>`;
        return;
      }

      cacheAll = r.complaints;

      let list = cacheAll;
      if (q) {
        list = list.filter(x =>
          String(x.id||'').toLowerCase().includes(q) ||
          String(x.complainantName||'').toLowerCase().includes(q) ||
          String(x.locations||'').toLowerCase().includes(q)
        );
      }

      document.getElementById('cAll2').textContent = list.length;

      if (!list.length) {
        cont.innerHTML = `<div class="empty"><i class="fa-solid fa-inbox"></i> لا توجد نتائج</div>`;
        return;
      }

      cont.innerHTML = buildTable(list, { showAssigned:true });
    }

