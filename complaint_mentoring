    /* ---------------- Utilities / normalization ---------------- */
    function normalizeComplaint(c) {
      // يدعم مفاتيح متعددة لأن عندك سكربتات مختلفة
      return {
        id: c.id || c.Complaint_ID || c.complaintId || '',
        date: c.date || c.Submit_Date || c.submitDate || '',
        time: c.time || c.Submit_Time || c.submitTime || '',
        complaintType: c.complaintType || c.Complaint_Type || c.type || '',
        complainantName: c.complainantName || c.Complainant_Name || c.complainant || '',
        complainantPhone: c.complainantPhone || c.Complainant_Phone || c.phone || '',
        complainantEmail: c.complainantEmail || c.Complainant_Email || c.email || '',
        complaintDateTime: c.complaintDateTime || c.Complaint_DateTime || '',
        locations: c.locations || c.Locations || c.location || '',
        complaintAgainst: c.complaintAgainst || c.Complaint_Against || '',
        complaintDescription: c.complaintDescription || c.Description || c.description || '',
        description: c.description || '',
        attachments: c.attachments || c.Attachments || '',
        additionalNotes: c.additionalNotes || c.Additional_Notes || '',
        status: c.status || c.Status || 'new',
        priority: c.priority || c.Priority || 'medium',
        assignedTo: c.assignedTo || c.Assigned_To || '',
        resolution: c.resolution || c.Resolution || ''
      };
    }

    function buildAssignedOptions(selected) {
      // الأفضل: assignmentList إن موجودة، وإلا staffList
      const source = (Array.isArray(assignmentList) && assignmentList.length)
        ? assignmentList
        : (staffList || []).map(s => s.name);

      const uniq = [...new Set(source.filter(Boolean))];
      return uniq.map(n => {
        const sel = (String(selected||'') === String(n)) ? 'selected' : '';
        return `<option value="${escapeHtml(n)}" ${sel}>${escapeHtml(n)}</option>`;
      }).join('');
    }

    function attachmentsToHtml(text) {
      const lines = String(text || '').split('\n').map(x => x.trim()).filter(Boolean);
      if (!lines.length) return `<div class="mini muted">لا يوجد</div>`;

      // يسمح بصيغ: "name | url" أو "url"
      const imgs = lines.map(line => {
        const parts = line.split('|');
        const url = (parts[1] || parts[0] || '').trim();
        const name = (parts[1] ? (parts[0] || '').trim() : '').trim();
        if (!url) return '';
        const safeUrl = escapeAttr(url);
        return `
          <a href="${safeUrl}" target="_blank" style="display:block;text-decoration:none">
            <div style="width:170px">
              <img src="${safeUrl}" style="width:170px;height:170px;object-fit:cover;border-radius:14px;border:1px solid var(--gray2);background:#fff">
              <div class="mini muted" style="margin-top:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHtml(name || 'فتح الملف')}</div>
            </div>
          </a>`;
      }).join('');

      return `<div style="display:flex;flex-wrap:wrap;gap:10px">${imgs}</div>`;
    }

    function escapeHtml(s){
      return String(s ?? '')
        .replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;')
        .replaceAll('"','&quot;').replaceAll("'","&#039;");
    }
    function escapeAttr(s){ return escapeHtml(s).replaceAll('`','&#096;'); }
    function escapeJs(s){ return String(s ?? '').replaceAll('\\','\\\\').replaceAll("'","\\'"); }

    /* ---------------- Init ---------------- */
    (async function init(){
      restoreLogin();
      await loadStaff();
      if (currentUser?.name) await refreshAll();
    })();
  </script>
</body>
</html>
