    function closeModal() {
      document.getElementById('modal').classList.remove('active');
      document.getElementById('modalBody').innerHTML = '';
    }

    async function saveAction(id) {
      const assignedTo = document.getElementById('mAssigned')?.value || '';
      const status = document.getElementById('mStatus')?.value || 'new';
      const priority = document.getElementById('mPriority')?.value || 'medium';
      const resolution = document.getElementById('mResolution')?.value || '';
      const notes = document.getElementById('mNotes')?.value || '';

      const r = await api('updateComplaint', {
        complaintId: id,
        assignedTo,
        status,
        priority,
        resolution,
        notes,
        actionBy: currentUser?.name || ''
      });

      if (!r.ok || r.success === false) {
        alert('فشل الحفظ: ' + (r.error || 'Unknown'));
        return;
      }
      alert('تم الحفظ');
      closeModal();
      await refreshAll();
    }

    async function quickClose(id) {
      const resolution = (document.getElementById('mResolution')?.value || '').trim();
      const notes = (document.getElementById('mNotes')?.value || '').trim();
      if (!resolution) {
        alert('اكتب الحل أولاً قبل الإغلاق');
        return;
      }
      const r = await api('closeComplaint', {
        complaintId: id,
        resolution,
        closedBy: currentUser?.name || '',
        notes
      });
      if (!r.ok || r.success === false) {
        alert('فشل الإغلاق: ' + (r.error || 'Unknown'));
        return;
      }
      alert('تم الإغلاق');
      closeModal();
      await refreshAll();
    }

