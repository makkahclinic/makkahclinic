            </div>
            <div style="width:48px;text-align:left;font-weight:900">${v}</div>
          </div>`;
      });
      html += `</div></div>`;

      // By status cards
      html += `<div class="box" style="background:#fff">
        <div style="font-family:'Cairo',sans-serif;font-weight:900;color:var(--blue-dark);margin-bottom:10px">
          حسب الحالة
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px">`;
