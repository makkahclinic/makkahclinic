<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>لوحة متابعة الشكاوى | مجمع مكة الطبي</title>

  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Tajawal:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <style>
    :root{
      --crimson:#9E1B32; --blue:#0056A3; --blue-dark:#003E75;
      --white:#fff; --off:#F8F9FA; --gray:#6C757D; --gray2:#E9ECEF; --dark:#343A40;
      --success:#28a745; --warning:#ffc107; --danger:#dc3545; --purple:#6f42c1;
      --shadow:0 6px 24px rgba(0,0,0,.12);
      --r:14px;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Tajawal',sans-serif;background:#f0f2f5;min-height:100vh;color:#111}

    /* Header */
    .header{
      background:linear-gradient(135deg,var(--blue-dark),var(--crimson));
      color:#fff;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;
      position:sticky;top:0;z-index:50;
      box-shadow:0 6px 18px rgba(0,0,0,.18);
    }
    .header-left{display:flex;align-items:center;gap:12px}
    .header-left h1{font-family:'Cairo',sans-serif;font-size:1.2rem}
    .header-left small{opacity:.85}
    .user-pill{
      background:rgba(255,255,255,.15);padding:8px 14px;border-radius:999px;display:flex;align-items:center;gap:8px;
      font-weight:600;
    }
    .actions{display:flex;gap:8px;flex-wrap:wrap}
    .btn{
      border:0;border-radius:12px;padding:10px 14px;font-family:'Tajawal',sans-serif;font-weight:700;
      cursor:pointer;display:inline-flex;align-items:center;gap:8px;transition:.2s;white-space:nowrap;
    }
    .btn:hover{transform:translateY(-1px)}
    .btn.light{background:rgba(255,255,255,.18);color:#fff}
    .btn.primary{background:var(--blue);color:#fff}
    .btn.success{background:var(--success);color:#fff}
    .btn.danger{background:var(--danger);color:#fff}
    .btn.gray{background:var(--gray2);color:var(--dark)}
    .btn:disabled{opacity:.6;cursor:not-allowed;transform:none}

    /* Layout */
    .container{max-width:1400px;margin:0 auto;padding:18px}
    .tabs{
      display:flex;gap:6px;background:var(--white);padding:6px;border-radius:var(--r);box-shadow:0 2px 10px rgba(0,0,0,.08);
      overflow:auto;margin-bottom:14px
    }
    .tab{
      border:0;background:transparent;padding:12px 14px;border-radius:12px;cursor:pointer;
      font-family:'Tajawal',sans-serif;font-weight:800;color:var(--gray);
      display:flex;align-items:center;gap:8px;white-space:nowrap
    }
    .tab.active{background:var(--blue);color:#fff}
    .count{background:rgba(0,0,0,.12);padding:2px 10px;border-radius:999px;font-size:.8rem}
    .tab.active .count{background:rgba(255,255,255,.25)}

    .grid-stats{
      display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:14px
    }
    .stat{
      background:var(--white);border-radius:var(--r);box-shadow:0 2px 10px rgba(0,0,0,.08);
      padding:16px;border-top:4px solid var(--blue)
    }
    .stat.warning{border-top-color:var(--warning)}
    .stat.success{border-top-color:var(--success)}
    .stat.danger{border-top-color:var(--danger)}
    .stat.purple{border-top-color:var(--purple)}
    .stat .num{font-family:'Cairo',sans-serif;font-size:2rem;font-weight:900;color:var(--blue-dark)}
    .stat .lbl{color:var(--gray);font-size:.9rem}

    .card{
      background:var(--white);border-radius:var(--r);box-shadow:0 2px 10px rgba(0,0,0,.08);overflow:hidden;margin-bottom:14px
    }
    .card-h{
      padding:14px 16px;border-bottom:1px solid var(--gray2);
      display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap
    }
    .card-h h3{font-family:'Cairo',sans-serif;font-size:1.05rem;color:var(--blue-dark);display:flex;align-items:center;gap:10px}
    .card-b{padding:16px}

    .filters{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}
    select,input{
      padding:10px 12px;border:1px solid var(--gray2);border-radius:12px;font-family:'Tajawal',sans-serif;min-width:180px;
      background:#fff
    }

    .table-wrap{overflow:auto}
    table{width:100%;border-collapse:collapse}
    th,td{padding:12px;border-bottom:1px solid var(--gray2);text-align:right;vertical-align:top}
    th{background:var(--off);color:var(--blue-dark);font-weight:900;white-space:nowrap}
    tr:hover{background:var(--off)}
    .badge{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:.82rem;font-weight:900}
    .b-new{background:rgba(255,193,7,.2);color:#856404}
    .b-prog{background:rgba(0,86,163,.15);color:#0056A3}
    .b-res{background:rgba(40,167,69,.15);color:#28a745}
    .b-closed{background:rgba(108,117,125,.2);color:#6c757d}
    .b-high{background:rgba(220,53,69,.15);color:var(--danger)}
    .b-med{background:rgba(255,193,7,.18);color:#856404}
    .b-low{background:rgba(0,86,163,.12);color:var(--blue)}

    .mini{font-size:.85rem;color:var(--gray)}
    .muted{color:var(--gray)}

    /* Login overlay */
    .overlay{
      position:fixed;inset:0;background:linear-gradient(135deg,var(--blue-dark),var(--crimson));
      display:flex;align-items:center;justify-content:center;padding:18px;z-index:9999
    }
    .overlay.hidden{display:none}
    .login{
      background:#fff;border-radius:18px;box-shadow:var(--shadow);max-width:430px;width:100%;
      padding:28px;text-align:center
    }
    .logo{
      width:78px;height:78px;border-radius:50%;margin:0 auto 14px;
      background:linear-gradient(135deg,var(--blue),var(--crimson));
      display:flex;align-items:center;justify-content:center;color:#fff;font-size:2rem
    }
    .login h2{font-family:'Cairo',sans-serif;color:var(--blue-dark);margin-bottom:4px}
    .login p{color:var(--gray);margin-bottom:16px}
    .err{display:none;color:var(--danger);margin-top:10px;font-weight:800}

    /* Modal */
    .modal{
      position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;align-items:center;justify-content:center;z-index:9990;padding:18px
    }
    .modal.active{display:flex}
    .modal-box{
      background:#fff;border-radius:18px;box-shadow:var(--shadow);max-width:980px;width:100%;
      max-height:90vh;overflow:auto
    }
    .modal-h{
      position:sticky;top:0;z-index:5;
      background:linear-gradient(135deg,var(--blue),var(--crimson));color:#fff;
      padding:14px 16px;display:flex;align-items:center;justify-content:space-between
    }
    .modal-h h3{font-family:'Cairo',sans-serif;font-size:1.05rem;display:flex;align-items:center;gap:10px}
    .close{background:none;border:0;color:#fff;font-size:1.7rem;cursor:pointer}
    .modal-b{padding:16px}

    .section{margin-bottom:14px}
    .section h4{
      font-family:'Cairo',sans-serif;color:var(--blue-dark);margin-bottom:10px;
      display:flex;align-items:center;gap:10px;border-bottom:2px solid var(--gray2);padding-bottom:8px
    }
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
    .box{background:var(--off);border-radius:12px;padding:12px}
    .box .k{font-size:.78rem;color:var(--gray);margin-bottom:4px}
    .box .v{font-weight:900}
    .text{background:var(--off);border-radius:12px;padding:12px;line-height:1.7}
    .actions-bar{background:linear-gradient(135deg,#f8f9fa,#e9ecef);border-radius:14px;padding:14px;margin-top:10px}
    textarea{min-height:90px;resize:vertical}

    .loading{padding:40px;text-align:center;color:var(--gray)}
    .loading i{font-size:2rem;margin-bottom:10px;display:block}
    .empty{padding:40px;text-align:center;color:var(--gray)}
    .empty i{font-size:3.2rem;opacity:.3;margin-bottom:10px;display:block}

    @media (max-width:768px){
      .container{padding:12px}
      .header-left h1{font-size:1.05rem}
      select,input{min-width:140px}
    }
  </style>
</head>

<body>

  <!-- Login -->
  <div id="overlay" class="overlay">
    <div class="login">
      <div class="logo"><i class="fa-solid fa-shield-heart"></i></div>
      <h2>لوحة متابعة الشكاوى</h2>
      <p>مجمع مكة الطبي بالزاهر</p>

      <select id="staffSelect">
        <option value="">جاري التحميل...</option>
      </select>

      <input id="passcode" type="password" placeholder="الرمز السري" style="text-align:center;letter-spacing:8px;font-size:1.1rem">

      <button id="btnLogin" class="btn primary" style="width:100%;justify-content:center" onclick="login()">
        <i class="fa-solid fa-right-to-bracket"></i> دخول
      </button>

      <div id="loginErr" class="err"></div>
    </div>
  </div>

  <!-- Header -->
  <header class="header">
    <div class="header-left">
      <i class="fa-solid fa-comments" style="font-size:1.7rem"></i>
      <div>
        <h1>تحليل ومتابعة الشكاوى</h1>
        <small>لجنة إدارة المخاطر — نظام التحليل والإجراءات</small>
      </div>
    </div>

    <div class="user-pill">
      <i class="fa-solid fa-user-circle"></i>
      <span id="userName">-</span>
    </div>

    <div class="actions">
      <button class="btn light" onclick="refreshAll()"><i class="fa-solid fa-rotate"></i> تحديث</button>
      <button class="btn light" onclick="logout()"><i class="fa-solid fa-arrow-right-from-bracket"></i></button>
    </div>
  </header>

  <main class="container">

    <div class="tabs">
      <button class="tab active" data-tab="dash"><i class="fa-solid fa-chart-pie"></i> لوحة <span class="count" id="cAll">0</span></button>
      <button class="tab" data-tab="all"><i class="fa-solid fa-list"></i> الكل <span class="count" id="cAll2">0</span></button>
      <button class="tab" data-tab="new"><i class="fa-solid fa-clock"></i> جديدة <span class="count" id="cNew">0</span></button>
      <button class="tab" data-tab="prog"><i class="fa-solid fa-spinner"></i> قيد المعالجة <span class="count" id="cProg">0</span></button>
      <button class="tab" data-tab="hist"><i class="fa-solid fa-file-lines"></i> تقرير تاريخي</button>
    </div>

    <!-- Dashboard -->
    <section id="dash" class="tabPage">
      <div class="grid-stats">
        <div class="stat"><div class="num" id="sTotal">-</div><div class="lbl">إجمالي الشكاوى</div></div>
        <div class="stat warning"><div class="num" id="sNew">-</div><div class="lbl">جديدة</div></div>
        <div class="stat"><div class="num" id="sProg">-</div><div class="lbl">قيد المعالجة</div></div>
        <div class="stat success"><div class="num" id="sClosed">-</div><div class="lbl">مغلقة</div></div>
        <div class="stat purple"><div class="num" id="sAvg">-</div><div class="lbl">متوسط أيام الإغلاق</div></div>
      </div>

      <div class="card">
        <div class="card-h">
          <h3><i class="fa-solid fa-chart-column"></i> تحليل سريع</h3>
          <div class="mini muted" id="lastSync">—</div>
        </div>
        <div class="card-b" id="charts">
          <div class="loading"><i class="fa-solid fa-spinner fa-spin"></i> جاري التحليل...</div>
        </div>
      </div>
    </section>

    <!-- All -->
    <section id="all" class="tabPage" style="display:none">
      <div class="card">
        <div class="card-h">
          <h3><i class="fa-solid fa-list"></i> جميع الشكاوى</h3>
        </div>
        <div class="card-b">
          <div class="filters">
            <select id="fStatus" onchange="loadAll()">
              <option value="all">كل الحالات</option>
              <option value="new">جديدة</option>
              <option value="in_progress">قيد المعالجة</option>
              <option value="resolved">تم الحل</option>
              <option value="closed">مغلقة</option>
            </select>
            <select id="fType" onchange="loadAll()">
              <option value="all">كل الأنواع</option>
              <option value="شكوى موظف">شكوى موظف</option>
              <option value="شكوى مريض">شكوى مريض</option>
              <option value="شكوى زائر">شكوى زائر</option>
            </select>
            <input id="fSearch" placeholder="بحث (رقم شكوى / اسم / موقع)" oninput="loadAll()" />
          </div>
          <div id="tblAll" class="table-wrap">
            <div class="loading"><i class="fa-solid fa-spinner fa-spin"></i></div>
          </div>
        </div>
      </div>
    </section>

    <!-- New -->
    <section id="new" class="tabPage" style="display:none">
      <div class="card">
        <div class="card-h"><h3><i class="fa-solid fa-clock"></i> الشكاوى الجديدة</h3></div>
        <div class="card-b">
          <div id="tblNew" class="table-wrap"><div class="loading"><i class="fa-solid fa-spinner fa-spin"></i></div></div>
        </div>
      </div>
    </section>

    <!-- In progress -->
    <section id="prog" class="tabPage" style="display:none">
      <div class="card">
        <div class="card-h"><h3><i class="fa-solid fa-spinner"></i> قيد المعالجة</h3></div>
        <div class="card-b">
          <div id="tblProg" class="table-wrap"><div class="loading"><i class="fa-solid fa-spinner fa-spin"></i></div></div>
        </div>
      </div>
    </section>

    <!-- History -->
    <section id="hist" class="tabPage" style="display:none">
      <div class="card">
        <div class="card-h"><h3><i class="fa-solid fa-filter"></i> فلترة التقرير</h3></div>
        <div class="card-b">
          <div class="filters">
            <div>
              <div class="mini" style="margin:0 2px 6px">من</div>
              <input type="date" id="hFrom">
            </div>
            <div>
              <div class="mini" style="margin:0 2px 6px">إلى</div>
              <input type="date" id="hTo">
            </div>
            <select id="hType">
              <option value="all">كل الأنواع</option>
              <option value="شكوى موظف">شكوى موظف</option>
              <option value="شكوى مريض">شكوى مريض</option>
              <option value="شكوى زائر">شكوى زائر</option>
            </select>
            <select id="hStatus">
              <option value="all">كل الحالات</option>
              <option value="new">جديدة</option>
              <option value="in_progress">قيد المعالجة</option>
              <option value="resolved">تم الحل</option>
              <option value="closed">مغلقة</option>
            </select>
            <button class="btn primary" onclick="loadHistory()"><i class="fa-solid fa-magnifying-glass"></i> بحث</button>
            <button class="btn success" onclick="exportHistory()"><i class="fa-solid fa-file-excel"></i> Excel</button>
            <button class="btn gray" onclick="printHistory()"><i class="fa-solid fa-print"></i> طباعة</button>
          </div>
          <div id="histMeta" class="mini muted">—</div>
        </div>
      </div>

      <div class="card">
        <div class="card-h">
          <h3><i class="fa-solid fa-file-lines"></i> نتائج التقرير</h3>
          <span class="badge b-prog" id="histCount">0</span>
        </div>
        <div class="card-b" id="histBody">
          <div class="empty"><i class="fa-solid fa-magnifying-glass"></i> اختر الفلاتر واضغط بحث</div>
        </div>
      </div>
    </section>

  </main>

  <!-- Modal -->
  <div id="modal" class="modal">
    <div class="modal-box">
      <div class="modal-h">
        <h3><i class="fa-solid fa-file-circle-check"></i> تفاصيل الشكوى</h3>
        <button class="close" onclick="closeModal()">&times;</button>
      </div>
      <div class="modal-b" id="modalBody"></div>
    </div>
  </div>

  <script>
    // ✅ ضع رابط الويب آب الصحيح هنا
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyE0nbyfYrDZeOHr6TuEQP7ivpOLF1pLmBFoF7fkDmNjQp5g6dW4i0xkcSBJJRaoOCVAw/exec";

    const STATUS_BADGE = {
      new: 'b-new',
      in_progress: 'b-prog',
      resolved: 'b-res',
      closed: 'b-closed'
    };
    const STATUS_NAME = {
      new: 'جديدة',
      in_progress: 'قيد المعالجة',
      resolved: 'تم الحل',
      closed: 'مغلقة'
    };

    let currentUser = null;
    let staffList = [];
    let assignmentList = [];
    let escalationList = [];

    let cacheAll = [];        // latest fetched list
    let cacheHistory = [];    // latest history results

    /* ---------------- API ---------------- */
    async function api(action, payload = {}) {
      const res = await fetch(SCRIPT_URL, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify({ action, payload }),
        redirect: "follow"
      });
      const text = await res.text();
      try { return JSON.parse(text); }
      catch { return { ok:false, error:"Invalid JSON response", raw:text }; }
    }

    /* ---------------- Login ---------------- */
    async function loadStaff() {
      const sel = document.getElementById('staffSelect');
      sel.innerHTML = `<option value="">جاري التحميل...</option>`;
      const r = await api('getComplaintStaff', {});
      if (!r.ok) {
        sel.innerHTML = `<option value="">فشل تحميل الأسماء</option>`;
        return;
      }
      staffList = r.staff || [];
      assignmentList = r.assignment || [];
      escalationList = r.escalation || [];

      const usable = staffList.filter(s => s.hasCode);
      sel.innerHTML = `<option value="">اختر اسمك للدخول</option>` +
        usable.map(s => `<option value="${escapeHtml(s.name)}">${escapeHtml(s.name)}</option>`).join('');
    }

    async function login() {
      const name = document.getElementById('staffSelect').value;
      const pass = document.getElementById('passcode').value;
      const err = document.getElementById('loginErr');
      const btn = document.getElementById('btnLogin');

      err.style.display = 'none';
      if (!name) return showErr('اختر اسمك أولًا');
      if (!pass) return showErr('أدخل الرمز السري');

      btn.disabled = true;
      btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> جاري التحقق...`;

      const r = await api('verifyComplaintPasscode', { staffName: name, passcode: pass });
      if (r.ok && r.verified) {
        currentUser = { name };
        localStorage.setItem('complaint_user', JSON.stringify(currentUser));
        document.getElementById('userName').textContent = name;
        document.getElementById('overlay').classList.add('hidden');
        await refreshAll();
      } else {
        showErr(r.error || 'بيانات الدخول غير صحيحة');
      }

      btn.disabled = false;
      btn.innerHTML = `<i class="fa-solid fa-right-to-bracket"></i> دخول`;

      function showErr(msg){
        err.textContent = msg;
        err.style.display = 'block';
      }
    }

    function logout() {
      localStorage.removeItem('complaint_user');
      currentUser = null;
      document.getElementById('overlay').classList.remove('hidden');
      document.getElementById('userName').textContent = '-';
    }

    function restoreLogin() {
      const saved = localStorage.getItem('complaint_user');
      if (!saved) return;
      try {
        currentUser = JSON.parse(saved);
        document.getElementById('userName').textContent = currentUser?.name || '-';
        document.getElementById('overlay').classList.add('hidden');
      } catch {}
    }

    /* ---------------- UI Tabs ---------------- */
    document.querySelectorAll('.tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tabPage').forEach(p => p.style.display = 'none');
        btn.classList.add('active');
        document.getElementById(btn.dataset.tab).style.display = 'block';
        if (btn.dataset.tab === 'hist') initHistoryDates();
      });
    });

    /* ---------------- Data loading ---------------- */
    async function refreshAll() {
      await Promise.all([
        loadStats(),
        loadAll(),
        loadNew(),
        loadProg()
      ]);
      document.getElementById('lastSync').textContent = 'آخر تحديث: ' + new Date().toLocaleString('ar-SA');
    }

    async function loadStats() {
      const r = await api('getComplaintStats', {});
      if (!r.ok) {
        document.getElementById('charts').innerHTML = `<div class="empty"><i class="fa-solid fa-triangle-exclamation"></i> فشل تحميل الإحصائيات</div>`;
        return;
      }
      document.getElementById('sTotal').textContent = r.total ?? 0;
      document.getElementById('sNew').textContent = r.new ?? 0;
      document.getElementById('sProg').textContent = r.in_progress ?? 0;
      document.getElementById('sClosed').textContent = r.closed ?? 0;
      document.getElementById('sAvg').textContent = r.avgResolutionTime ?? 0;

      // counts in tabs
      document.getElementById('cAll').textContent = r.total ?? 0;
      document.getElementById('cAll2').textContent = r.total ?? 0;
      document.getElementById('cNew').textContent = r.new ?? 0;
      document.getElementById('cProg').textContent = r.in_progress ?? 0;

      renderCharts(r);
    }

    function renderCharts(stats) {
      const byType = stats.byType || {};
      const byStatus = stats.byStatus || {
        new: stats.new || 0,
        in_progress: stats.in_progress || 0,
        resolved: stats.resolved || 0,
        closed: stats.closed || 0
      };

      const total = stats.total || 0;

      let html = `<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px;">`;

      // By type bars
      html += `<div class="box" style="background:#fff">
        <div style="font-family:'Cairo',sans-serif;font-weight:900;color:var(--blue-dark);margin-bottom:10px">
          حسب نوع الشكوى
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">`;
      Object.entries(byType).sort((a,b)=>b[1]-a[1]).forEach(([k,v]) => {
        const pct = total ? Math.round((v/total)*100) : 0;
        html += `
          <div style="display:flex;align-items:center;gap:10px">
            <div style="flex:1;min-width:110px">${escapeHtml(k)}</div>
            <div style="flex:2;background:var(--gray2);height:18px;border-radius:999px;overflow:hidden">
